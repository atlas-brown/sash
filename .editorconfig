# https://editorconfig.org/

# Top-most EditorConfig file
root = true

# Use Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Use UTF-8
[*]
charset = utf-8

# Use 4 space indentation
[*.{sh,py}]
indent_style = space
indent_size = 4
